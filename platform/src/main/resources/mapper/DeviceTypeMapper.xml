<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.DeviceTypeMapper">
    <resultMap id="deviceTypeResultMap" type="demo.lowcode.platform.entity.DeviceType">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="model" property="model" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
    </resultMap>

    <!--获取领域设备类型列表-->
    <select id="selectByDomainId" resultMap="deviceTypeResultMap">
        SELECT * FROM devicetype
        WHERE id IN (
            SELECT component_id FROM domain_component
            WHERE domain_id = #{domainId} AND component_type = 'devicetype'
        )
    </select>

    <!--根据code获取设备类型-->
    <select id="selectByCode" resultMap="deviceTypeResultMap">
        SELECT * FROM devicetype
        WHERE code = #{code}
    </select>

    <!--获取场景设备类型列表-->
    <select id="selectBySceneId" resultMap="deviceTypeResultMap">
        SELECT * FROM devicetype
        WHERE id IN (
            SELECT component_id FROM domain_component
            WHERE domain_id = (
                SELECT domain_id FROM scene WHERE scene_id = #{sceneId}
            )
            AND component_type = 'devicetype'
        )
    </select>
</mapper>
