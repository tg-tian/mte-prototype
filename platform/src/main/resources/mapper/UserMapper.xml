<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.UserMapper">

    <!--获取用户信息-->
    <select id="login" parameterType="demo.lowcode.platform.dto.UserLogin" resultType="demo.lowcode.platform.entity.User">
        SELECT * FROM sys_user_info WHERE user_name=#{userLogin.username} and password=#{userLogin.password}
    </select>

</mapper>