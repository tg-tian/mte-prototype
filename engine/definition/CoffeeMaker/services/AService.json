{
  "code": "AService",
  "name": "A公司",
  "description": "A公司咖啡机可以做（摩卡，没事）咖啡，支持（加糖，加奶）操作",
  "device": "coffeemaker",
  "parameters": {
    "coffeeType": [],
    "sugar": [],
    "uri": "",
    "protocol": "",
    "address": "",
    "port": ""
    },
  "commands": [
    {
      "signature": "getProperty()",
      "body": "Map<String, Object> result = new HashMap<>();\n        result.put( {{ coffeeType[0,1] }} );\n        return result;"
    },
    {
      "signature": "start()",
      "body": "System.out.println(\"Accessing URI: \" + {{uri}} + \"on\");"
    },
    {
      "signature": "makeCoffee(LinkedHashMap executeArgs)",
      "body": "System.out.println(\"Accessing URI: \" + {{uri}} + \"makeCoffee\");\n        System.out.println(executeArgs);"
    }
  ]
}




