{
  "code": "AService",
  "name": "A品牌",
  "device": "CoffeeMaker",
  "parameters": [
    {
      "code": "uri",
      "type": "String",
      "default": "",
      "canInitial": true
    },
    {
      "code": "coffeeType",
      "type": "List<String>",
      "default": ["摩卡","美式"],
      "canInitial": false
    },
    {
      "code": "sugar",
      "type": "List<Double>",
      "default": [0.3 , 0.5 , 0.8 , 1.0],
      "canInitial": false
    }
  ],
  "commands": [
    {
      "signature": "getProperty()",
      "output": "Map<String, Object>",
      "body": "Map<String, Object> result = new HashMap<>();\n        result.put(\"coffeeType\",coffeeType);\n        return result;"
    },
    {
      "signature": "start()",
      "output": "void",
      "body": "System.out.println(\"Accessing URI: \" + uri + \"on\");"
    },
    {
      "signature": "makeCoffee(LinkedHashMap executeArgs)",
      "output": "void",
      "body": "System.out.println(\"Accessing URI: \" + uri + \"makeCoffee\");\n        System.out.println(executeArgs);"
    }
  ]
}
