{
  "code": "CoffeeMaker",
  "name": "咖啡机器人",
  "type": "Device",
  "refs": [
    {
      "refID": "events",
      "refPath": "CoffeeMakerEvent.json"
    },
    {
      "refID": "services",
      "refPath": [
        {
          "name": "AService",
          "path": "services/AService.json"
        },
        {
          "name": "BService",
          "path": "services/BService.json"
        }
      ]
    }
  ],
  "commands": [
    {
      "code": "start",
      "name": "启动",
      "inputParam": [],
      "outputParam": "void",
      "events": [],
      "services": ["AService"]
    },
    {
      "code": "makeCoffee",
      "name": "做咖啡",
      "inputParam": [{
        "code": "coffeeType",
        "name": "咖啡类型",
        "type": "Enum",
        "options": ["摩卡", "美式"]
      }],
      "outputParam": "void",
      "events": [
        "onMakeCoffeeStart",
        "onMakeCoffeeComplete",
        "onMakeCoffeeError"
      ],
      "services": [
        "AService",
        "BService"
      ]
    },
    {
      "code": "check",
      "name": "检查",
      "inputParam": [],
      "outputParam": "void",
      "events": [],
      "services": [
        "AService",
        "BService"
      ]
    }]
}
