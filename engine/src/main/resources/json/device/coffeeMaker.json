{
  "type": "coffeeMaker",
  "commands": ["start", "makeCoffee", "check"],
  "events": [
    "onStartStart",
    "onStartComplete",
    "onStartError",
    "onMakeCoffeeStart",
    "onMakeCoffeeComplete",
    "onMakeCoffeeError",
    "onCheckStart",
    "onCheckComplete",
    "onCheckError"
  ],
  "services": [
    {
      "name": "AService",
      "operations": {
        "start": "on",
        "makeCoffee": "makeCoffee",
        "check": ""
      }
    },
    {
      "name": "BService",
      "operations": {
        "start": "start",
        "makeCoffee": "makeCoffee",
        "check": "check"
      }
    }
  ]
}
