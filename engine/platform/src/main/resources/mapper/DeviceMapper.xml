    <!--获取场景设备列表-->
    <select id="selectBySceneId" resultType="demo.lowcode.platform.entity.Device">
        SELECT * FROM device
        WHERE scene_id = #{sceneId}
    </select>

    <!--获取场景设备-->
    <select id="selectByCodeAndScene" resultType="demo.lowcode.platform.entity.Device">
        SELECT * FROM device
        WHERE scene_id = #{sceneId} AND device_code = #{code}
    </select>
</mapper>
