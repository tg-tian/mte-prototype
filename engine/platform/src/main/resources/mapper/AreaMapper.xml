<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="demo.lowcode.platform.mapper.AreaMapper">
    <!-- 根据场景 ID 获取区域列表 -->
    <select id="selectBySceneId" resultType="demo.lowcode.platform.entity.Area">
        SELECT * FROM area
        WHERE scene_id = #{sceneId}
    </select>

    <select id="selectById" resultType="demo.lowcode.platform.entity.Area">
        SELECT * FROM area
        WHERE id = #{id}
    </select>

</mapper>
