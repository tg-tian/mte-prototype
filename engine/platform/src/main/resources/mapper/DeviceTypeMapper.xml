<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.DeviceTypeMapper">

    <!-- 插入操作 -->
    <insert id="insertDeviceType"  keyProperty="deviceTypeId">
        INSERT INTO devicetype (deviceTypeCode, deviceTypeName, imgPath)
        VALUES (#{deviceTypeCode}, #{deviceTypeName}, #{imgPath})
    </insert>

</mapper>