<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.SceneMapper">

    <!--获取场景id-->
    <select id="getSceneId" resultType="java.lang.Long">
        SELECT sceneId FROM scene WHERE sceneCode = #{sceneCode}
    </select>

</mapper>