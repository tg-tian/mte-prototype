<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.SceneMapper">

    <!--获取场景id-->
    <select id="getSceneId" resultType="java.lang.Long">
        SELECT scene_id FROM scene WHERE scene_code = #{sceneCode}
    </select>

    <!--获取场景列表-->
    <select id="selectByDomainId" resultType="demo.lowcode.platform.entity.Scene">
        SELECT * FROM scene WHERE domain_id = #{domainId}
    </select>

    <select id="selectBySceneCode" resultType="demo.lowcode.platform.entity.Scene">
        SELECT * FROM scene WHERE scene_code = #{sceneCode}
    </select>
    
    <!--获取所有场景列表-->
    <select id="selectAll" resultType="demo.lowcode.platform.entity.Scene">
        SELECT * FROM scene
    </select>

</mapper>
