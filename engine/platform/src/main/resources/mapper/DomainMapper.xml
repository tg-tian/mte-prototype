<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.DomainMapper">

    <!--获取领域id-->
    <select id="getDomainIdByName" resultType="java.lang.Long">
        SELECT domainId FROM domain WHERE domainName = #{domainName}
    </select>

    <!--获取领域id-->
    <select id="getDomainIdByCode" resultType="java.lang.Long">
        SELECT domainId FROM domain WHERE domainCode = #{domainCode}
    </select>
</mapper>