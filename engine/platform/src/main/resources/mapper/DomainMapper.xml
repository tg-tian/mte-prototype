<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.DomainMapper">

    <!--获取领域id-->
    <select id="getDomainIdByName" resultType="java.lang.Long">
        SELECT domain_id FROM domain WHERE domain_name = #{domainName}
    </select>

    <!--获取领域-->
    <select id="getDomainByCode" resultType="demo.lowcode.platform.entity.Domain">
        SELECT * FROM domain WHERE domain_code = #{domainCode}
    </select>
</mapper>
