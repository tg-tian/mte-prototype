<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.DomainMapper">

    <!--设备计数-->
    <select id="getDomainId" resultType="java.lang.Long">
        SELECT domainId FROM domain WHERE domainName = #{domainName}
    </select>

</mapper>