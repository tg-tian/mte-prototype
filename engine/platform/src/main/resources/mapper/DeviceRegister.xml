<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="demo.lowcode.platform.mapper.DeviceRegisterMapper">

    <!--统计设备注册数-->
    <select id="countRegister" resultType="int">
        SELECT COUNT(1) FROM register WHERE deviceId = #{deviceId} AND sceneId = #{sceneId}
    </select>

    <!--查询某个场景注册的所有设备-->
    <select id="selectBysceneId" resultType="demo.lowcode.platform.entity.DeviceRegister">
        SELECT * FROM  register WHERE sceneId = #{sceneId}
    </select>
</mapper>